# ============================================
#  WeChat Server Docker 部署配置
#  修改后需要重启容器生效: docker compose restart wechat-server
# ============================================

# ---- 应用镜像（请改为你有权限拉取的镜像）----
WECHAT_SERVER_IMAGE=wechatserver/wechat-server:1.0.0

# ---- Docker 镜像源（国内加速，可选 docker.m.daocloud.io；海外可用 docker.io）----
REGISTRY=docker.m.daocloud.io

# ---- 应用配置 ----
APP_PORT=8848
ADMIN_KEY=
GH_WXID=

# ---- Worker 配置 ----
WORKER_POOL_SIZE=500
MAX_WORKER_TASK_LEN=1000

# ---- MySQL 配置 ----
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=weixin
MYSQL_USER=weixin
MYSQL_PASSWORD=weixin123
# 连接串中主机名须为 compose 服务名 mysql
MYSQL_CONNECT_STR=weixin:weixin123@tcp(mysql:3306)/weixin?charset=utf8mb4&parseTime=true&loc=Local

# ---- Redis 配置 ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASS=

# ---- 消息队列（按需） ----
TOPIC=wx_sync_msg_topic
NEWS_SYN_WXID=false
ROCKET_MQ_ENABLED=false
ROCKET_MQ_HOST=
RABBIT_MQ_ENABLED=false
RABBIT_MQ_URL=
KAFKA_ENABLED=false
KAFKA_URL=
